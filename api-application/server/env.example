# Скопируйте в .env рядом с сервисом или задайте в systemd Environment=
# Обязательно смените ключ в проде.

FARMPULSE_APP_API_KEY=сгенерируйте-длинную-случайную-строку

# Слушать только localhost (nginx проксирует с 443)
FARMPULSE_BIND_HOST=127.0.0.1
FARMPULSE_BIND_PORT=8000

# Опционально: при старте один раз подтянуть снимок ферм из JSON (как у PHP worker)
# FARMPULSE_BOOTSTRAP_CONFIG=/var/www/farmpulse/api/v2/farms/config.json
